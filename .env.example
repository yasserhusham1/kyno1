# نسخ هذا الملف إلى config/local.config.js (لا ترفعه إلى Git)
# Supabase — استخدم anon key فقط في الواجهة، NEVER service_role
#
# Netlify: لا حاجة لملف محلي — يُنشأ تلقائياً عبر tools/generate-local-config.js
# Env vars: BASMA_SUPABASE_URL, BASMA_SUPABASE_ANON_KEY, BASMA_APP_ENV=production

BASMA_SUPABASE_URL=https://your-project.supabase.co
BASMA_SUPABASE_ANON_KEY=your-anon-key-here

# KYNO ops — NEVER commit real values (local shell / CI secrets only)
# KYNO_TEST_PASSWORD=              # for tests/ and tools/run-db-proof-*.ps1
# KYNO_SUPER_ADMIN_PASSWORD=         # new password for tools/rotate-super-admin-password.ps1 (12+ chars)
# KYNO_SUPABASE_SERVICE_ROLE_KEY=    # Supabase Dashboard → Settings → API (server/CI only)
# KYNO_SUPER_ADMIN_USERNAME=yasser   # optional, default yasser

# إعدادات التطبيق
BASMA_APP_ENV=development
BASMA_STRICT_RLS=false
BASMA_AUTH_USE_COOKIES=true
# Enterprise v3 — RPC-only business writes (requires migrations 031+032)
BASMA_KYNO_RPC_MODE=false
# Final production lock — enables RPC mode + blocks direct table writes in frontend
# On Netlify with appEnv=production these default to true unless explicitly set false
BASMA_KYNO_FINAL_LOCKDOWN=false
BASMA_REALTIME_TABLES=employees,app_settings
